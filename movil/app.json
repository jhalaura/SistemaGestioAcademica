{
  "expo": {
    "name": "SGA Móvil",
    "slug": "sga-movil",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "backgroundColor": "#1a73e8"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sistemaacademico.movil",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Necesitamos acceso a tu ubicación para registrar la asistencia georreferenciada."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#1a73e8"
      },
      "package": "com.sistemaacademico.movil",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Necesitamos acceso a tu ubicación para registrar la asistencia."
        }
      ]
    ]
  }
}